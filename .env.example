# API (apps/api) — copy to apps/api/.env for local dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signal_lab?schema=public
PORT=3001
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=info
SIGNAL_LAB_SENTRY_DSN=

# Web (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# UI в браузере: прямой порт Grafana (прокси /grafana без настройки GF_SERVER_ROOT_URL ломает UI)
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3010
# Ссылка на проект в Sentry (Issues / stream)
NEXT_PUBLIC_SENTRY_PROJECT_URL=
NEXT_PUBLIC_LOKI_URL=http://localhost:3100
NEXT_PUBLIC_PROMETHEUS_URL=http://localhost:9090
NEXT_PUBLIC_METRICS_URL=http://localhost:3001/metrics
GRAFANA_INTERNAL_URL=http://127.0.0.1:3010
