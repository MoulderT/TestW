generator client {
  provider      = "prisma-client-js"
  // Docker (node:bookworm + openssl 3) needs this; "native" keeps local Windows/macOS dev
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ScenarioRun {
  id        String   @id @default(cuid())
  type      String
  status    String
  duration  Int?
  error     String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}
